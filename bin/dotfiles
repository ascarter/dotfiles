#!/bin/sh
# set -x
XDG_CONFIG_HOME=${XDG_CONFIG_HOME:=$HOME/.config}
DOTFILES="${DOTFILES:-${XDG_CONFIG_HOME}/dotfiles}"
DOTFILES_LIB=${DOTFILES_LIB:-${DOTFILES}/lib}
DOTFILES_PKGS=${DOTFILES_LIB}/packages
DOTFILES_THEME=${DOTFILES_THEME:-default}

source ${DOTFILES_LIB}/dotfiles.sh

usage() {
    echo "Usage: dotfiles [options] <subcommand> [package]"
    echo ""
    echo "Options:"
    echo "  -f    Force"
    echo "  -v    Verbose"
    echo ""
    echo "Subcommands:"
    echo "  install   Install [package]"
    echo "  list      List [package]"
    echo "  show      Show [package]"
    echo "  theme     Theme [theme]"
    echo "  uninstall Uninstall [package]"
    echo "  update    Update [package]"
}

dotfiles_install() {
    local packages=${1:-$(ls ${DOTFILES_PKGS})}

    # Prerequisites
    case "${ID}" in
    "macos")  macos_prereqs  ;;
    "fedora") fedora_prereqs ;;
    "ubuntu") ubuntu_prereqs ;;
    esac

    # Install each package
    for package in ${packages}; do
        local package_path=${DOTFILES_PKGS}/${package}
        if [ -d ${package_path} ]; then
            # Run install script if present
            log "Installing ${package} from ${package_path}"
            if [ -f ${package_path}/install.sh ]; then
                source ${package_path}/install.sh
            else
                log "${package} install script not found"
            fi
        else
            echo "==> Error: ${package} not found"
        fi
    done
}

dotfiles_uninstall() {
    echo "Uninstall [package]"
}

dotfiles_update() {
    echo "Updating [package]"
}

dotfiles_list() {
    echo "List [package]"
}

dotfiles_show() {
    echo "Show [package]"
}

dotfiles_theme() {
    echo "Theme [theme]"
}

# Parse command line arguments
while getopts "ft:v" opt; do
  case $opt in
    f ) FORCE=1 ;;
    v ) VERBOSE=1 ;;
    \?) usage && exit 1 ;;
  esac
done
shift $(($OPTIND - 1))

log "DOTFILES: ${DOTFILES}"
log "DOTFILES_LIB: ${DOTFILES_LIB}"

# Handle subcommands and pass remaining paramters
if [ $# -eq 0 ]; then
    echo "No subcommand specified"
    echo ""
    usage
    exit 1
fi

subcommand=$1
shift

case ${subcommand} in
"install")   dotfiles_install $* ;;
"list")      dotfiles_list $* ;;
"show")      dotfiles_show $* ;;
"theme")     dotfiles_theme $* ;;
"uninstall") dotfiles_uninstall $* ;;
"update")    dotfiles_update $* ;;
*)
    usage
    exit 1
    ;;
esac
