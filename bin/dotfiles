#!/usr/bin/env bash
#
# dotfiles management tool
#

set -eu

VERBOSE=0
FORCE=0
FORCE_ALL=0
QUIET=0

DOTFILES_HOME=$(realpath $(dirname $(realpath "$0"))/..)
DOTFILES_LIB_DIR="${DOTFILES_HOME}/lib"
DOTFILES_SCRIPTS_DIR="${DOTFILES_HOME}/scripts"
DOTFILES_HOST_DIR="${DOTFILES_HOME}/host"
export DOTFILES_HOME DOTFILES_LIB_DIR

# Load shared display/logging functions
source "${DOTFILES_LIB_DIR}/core.sh"

usage() {
  cat <<'EOF'
dotfiles - manage dotfiles repository

Usage:
  dotfiles [options] <command>

Commands:
  init        Bootstrap dotfiles environment (XDG dirs, shell, sync)
  shell       Configure zsh and shell bootstrap for dotfiles
  env         Export configuration for environment
  sync        Synchronize config
  uninstall   Uninstall dotfiles
  status      Show status of dotfiles
  update      Update dotfiles repository
  edit        Edit dotfiles repository using $EDITOR
  host        Host provisioning (init|status)
  gitconfig   Generate machine-specific ~/.gitconfig
  tool        Manage tools (install|uninstall|upgrade|clean|list|status [<toolname>])
  flatpak     Manage Flatpak apps (install|status)
  script      Run a script (list available scripts if no name given)

Options:
  -v          Enable verbose output
  -f          Force actions where applicable
  -h          Show this help message
EOF
}

# ------------------------------
# Helper functions
# ------------------------------

run_script() {
  script_name="$1"
  shift

  case "$script_name" in
  "" | /* | *..* | */../* | ../* | */..*)
    abort "invalid script path: $script_name"
    ;;
  esac

  script_path="${DOTFILES_SCRIPTS_DIR}/${script_name}.sh"

  [ -f "$script_path" ] || abort "script not found: $script_name"

  vlog "script" "running $script_name"
  ensure sh "$script_path" "$@"
}

# ------------------------------
# Commands
# ------------------------------

cmd_init() {
  # Create XDG directories
  : "${XDG_BIN_HOME:=$HOME/.local/bin}"
  : "${XDG_CONFIG_HOME:=$HOME/.config}"
  : "${XDG_DATA_HOME:=$HOME/.local/share}"
  : "${XDG_STATE_HOME:=$HOME/.local/state}"
  : "${XDG_CACHE_HOME:=$HOME/.cache}"
  : "${XDG_OPT_HOME:=$HOME/.local/opt}"

  for dir in "$XDG_BIN_HOME" "$XDG_CONFIG_HOME" "$XDG_DATA_HOME" "$XDG_STATE_HOME" "$XDG_CACHE_HOME" "$XDG_OPT_HOME"; do
    vlog "xdg" "ensuring $dir exists"
    [ -d "$dir" ] || mkdir -p "$dir"
  done

  cmd_shell
  cmd_sync

  success "Initialized dotfiles environment"
}

_detect_host_env() {
  if [ -f /run/.toolboxenv ]; then
    echo "toolbox"
    return
  fi
  platform_id
}

cmd_host() {
  subcommand="${1:-}"
  shift || true

  case "$subcommand" in
  init)
    env_override="${1:-}"
    if [ -n "$env_override" ]; then
      host_script="${DOTFILES_HOST_DIR}/${env_override}.sh"
      [ -f "$host_script" ] || abort "Unknown host environment: ${env_override}"
      ensure bash "$host_script"
    else
      detected="$(_detect_host_env)"
      host_script="${DOTFILES_HOST_DIR}/${detected}.sh"
      [ -f "$host_script" ] || abort "No provisioning script found for: ${detected}"
      ensure bash "$host_script"
    fi
    ;;
  status)
    detected="$(_detect_host_env)"
    log "env"      "${detected}"
    log "hostname" "$(hostname)"
    log "os"       "$(uname -srm)"
    if [ -f /etc/os-release ]; then
      . /etc/os-release
      log "distro"   "${PRETTY_NAME:-${ID:-unknown}}"
    fi
    log "shell"    "${SHELL:-unknown}"
    log "user"     "$(whoami)"
    ;;
  "")
    cat <<'EOF'
Usage:
  dotfiles host init [<env>]   Provision host OS (auto-detect or specify: macos|fedora|toolbox)
  dotfiles host status         Show host environment info
EOF
    exit 1
    ;;
  *)
    abort "Unknown host subcommand: ${subcommand}"
    ;;
  esac
}

cmd_env() {
  # zsh environment setup
  cat <<'EOF'
export XDG_BIN_HOME="${XDG_BIN_HOME:-$HOME/.local/bin}"
export XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
export XDG_DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
export XDG_STATE_HOME="${XDG_STATE_HOME:-$HOME/.local/state}"
export XDG_CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.cache}"
export XDG_OPT_HOME="${XDG_OPT_HOME:-$HOME/.local/opt}"
export XDG_OPT_BIN="${XDG_OPT_BIN:-$XDG_OPT_HOME/bin}"
export XDG_OPT_SHARE="${XDG_OPT_SHARE:-$XDG_OPT_HOME/share}"
export ZDOTDIR="${ZDOTDIR:-$XDG_CONFIG_HOME/zsh}"
export DOTFILES_HOME="${DOTFILES_HOME:-$XDG_DATA_HOME/dotfiles}"
typeset -U path
path=("$XDG_OPT_BIN" "$XDG_BIN_HOME" "$DOTFILES_HOME/bin" $path)
typeset -U manpath
manpath=("$XDG_OPT_SHARE/man" $manpath)
EOF
}

cmd_shell() {
  : "${XDG_DATA_HOME:=$HOME/.local/share}"
  : "${DOTFILES_HOME:=${XDG_DATA_HOME}/dotfiles}"

  zshenv="$HOME/.zshenv"
  bootstrap_line="eval \"\$(${DOTFILES_HOME}/bin/dotfiles env)\""

  if [ ! -f "${zshenv}" ] || ! grep -qE 'eval "\$\([^"]*bin/dotfiles env\)"' "${zshenv}"; then
    cat >>"${zshenv}" <<EOF
# dotfiles environment
${bootstrap_line}
EOF
  fi

  case "$(uname -s)" in
  Darwin)
    # Default shell is typically zsh on modern macOS.
    ;;
  Linux)
    zsh_path="$(command -v zsh || true)"
    [ -n "$zsh_path" ] || {
      warn "shell" "zsh not found; skipping login shell change"
      return 0
    }

    if ! getent passwd "$(whoami)" | grep -qE ":${zsh_path}$"; then
      chsh --shell "$zsh_path"
    fi
    ;;
  esac
}

cmd_sync() {
  source "${DOTFILES_LIB_DIR}/sync.sh"
  (_sync link) && log "sync" "ok"
}

cmd_script() {
  script_name="${1:-}"

  if [ -z "$script_name" ]; then
    find "$DOTFILES_SCRIPTS_DIR" -type f -name "*.sh" | sed "s|^$DOTFILES_SCRIPTS_DIR/||;s|\\.sh$||" | sort | while read -r script; do
      log "$script"
    done
    exit 0
  fi

  shift
  run_script "$script_name" "$@"
}

cmd_status() {
  source "${DOTFILES_LIB_DIR}/sync.sh"
  source "${DOTFILES_LIB_DIR}/tool.sh"
  source "${DOTFILES_LIB_DIR}/opt.sh"
  (_sync status) && log "status" "ok"
  printf "\n${tty_bold}tools${tty_reset}\n"
  local count=0
  while IFS= read -r f; do
    local name tag
    name="$(basename "$f")"
    tag="$(cat "$f")"
    printf "  %-16s %s\n" "$name" "$tag"
    count=$((count + 1))
  done < <(find "$TOOLS_STATE" -maxdepth 1 -type f 2>/dev/null | sort)
  [[ "$count" -gt 0 ]] || printf "  no tools installed\n"
}

cmd_uninstall() {
  source "${DOTFILES_LIB_DIR}/sync.sh"
  (_sync unlink) && log "unlink" "ok"
}

cmd_update() {
  # Suppress output except errors
  QUIET=1

  source "${DOTFILES_LIB_DIR}/sync.sh"

  # Unlink files before updating in case of structure changes
  cmd_uninstall || abort "failed to unlink files before update"

  # Update the repository
  log "git" "Updating dotfiles repository"
  git -C "$DOTFILES_HOME" pull --ff-only

  # Resync files after update
  cmd_sync || abort "failed to resync files after update"

  success "dotfiles updated"
}

cmd_edit() {
  "$EDITOR" "$DOTFILES_HOME"
}

cmd_gitconfig() {
  ensure bash "${DOTFILES_SCRIPTS_DIR}/gitconfig.sh" "$@"
}

cmd_tool() {
  source "${DOTFILES_LIB_DIR}/tool.sh"
  _tool_cmd "$@"
}

cmd_flatpak() {
  [[ "$(uname -s)" == "Linux" ]] || abort "flatpak subcommand is Linux only"
  command -v flatpak >/dev/null 2>&1 || abort "flatpak not found on PATH"
  source "${DOTFILES_LIB_DIR}/flatpak.sh"
  _flatpak_cmd "$@"
}

main() {
  cmd="$1"
  shift

  case "$cmd" in
  env | init | shell | sync | script | unlink | uninstall | status | update | edit | host | tool | flatpak | gitconfig)
    cmd_$cmd "$@"
    ;;
  help)
    usage
    ;;
  *)
    if [ -n "$cmd" ]; then
      error "Unknown command: $cmd"
    fi
    usage
    exit 1
    ;;
  esac
}

# Parse command line options
while getopts "vfh" opt; do
  case $opt in
  v) VERBOSE=1 ;;
  f) FORCE=1 ;;
  h | \?) usage && exit 0 ;;
  esac
done
shift $((OPTIND - 1))

# Require subcommand
[ $# -gt 0 ] || {
  usage >&2
  exit 1
}

main "$@"
